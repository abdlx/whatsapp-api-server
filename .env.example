# Server
PORT=3000
NODE_ENV=development

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Redis (Local)
REDIS_URL=redis://localhost:6379

# Security
# Run this to generate a 32-character key
# node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
API_KEY=your-secret-api-key
ALLOWED_IPS=127.0.0.1

# WhatsApp Anti-Ban
MAX_MESSAGES_PER_DAY=200
MIN_DELAY_MS=3000
MAX_DELAY_MS=8000
TYPING_SPEED_MS=50

# Human Behavior Simulation
# Set to your local timezone (e.g., 'America/New_York', 'Asia/Kolkata', 'Europe/London')
# This ensures messages are only sent during business hours in your timezone
DEFAULT_TIMEZONE=UTC
RESPECT_WEEKENDS=false

# Contact Protection
# Set to 'true' to BLOCK messages to unsaved contacts (safest)
# Set to 'false' to only WARN but still send (more flexible, higher risk)
BLOCK_UNSAVED_CONTACTS=false

# Monitoring (Optional)
ALERT_WEBHOOK_URL=

# Multi-instance networking (for clustered deployments)
# Set this to the internal hostname or IP of this specific pod/container
# so the session router can proxy requests to the correct instance.
# Leave as 'localhost' for single-instance deployments.
POD_HOST=localhost
